# Docker runtime config example.
# Mount this file to /etc/gpt-image-playground/config.env, or set APP_CONFIG_FILE
# to another path.

DEFAULT_API_URL=https://api.apikey.fun/v1
DEFAULT_API_MODE=responses
DEFAULT_MODEL=gpt-5.5
DEFAULT_API_TIMEOUT=1800
DEFAULT_CODEX_CLI=true
DEFAULT_REASONING_EFFORT=high
DISABLE_RESPONSE_STORAGE=true
RESPONSES_STREAM=true
RESPONSES_PARTIAL_IMAGES=1
API_PROXY_URL=https://api.apikey.fun/v1
API_PROXY_CONNECT_TIMEOUT=60s
API_PROXY_SEND_TIMEOUT=1800s
API_PROXY_READ_TIMEOUT=1800s
ENABLE_API_PROXY=true
LOCK_API_PROXY=true
HIDE_API_CONFIG=true
SHOW_API_CONFIG=false

# Optional. When set, Nginx sends this key to the upstream API and the browser
# no longer needs to store or send an API key.
API_PROXY_API_KEY=sk-your-key

# Optional. Set both values to protect the whole app and /api-proxy with Basic Auth.
BASIC_AUTH_USERNAME=friend
BASIC_AUTH_PASSWORD=change-this-password
