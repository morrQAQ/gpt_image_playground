# ---- Build stage ----
FROM --platform=$BUILDPLATFORM node:20-alpine AS build

WORKDIR /app

ENV VITE_DEFAULT_API_URL=__VITE_DEFAULT_API_URL_PLACEHOLDER__
ENV VITE_DEFAULT_API_MODE=__VITE_DEFAULT_API_MODE_PLACEHOLDER__
ENV VITE_DEFAULT_MODEL=__VITE_DEFAULT_MODEL_PLACEHOLDER__
ENV VITE_DEFAULT_API_TIMEOUT=__VITE_DEFAULT_API_TIMEOUT_PLACEHOLDER__
ENV VITE_DEFAULT_CODEX_CLI=__VITE_DEFAULT_CODEX_CLI_PLACEHOLDER__
ENV VITE_DEFAULT_REASONING_EFFORT=__VITE_DEFAULT_REASONING_EFFORT_PLACEHOLDER__
ENV VITE_DISABLE_RESPONSE_STORAGE=__VITE_DISABLE_RESPONSE_STORAGE_PLACEHOLDER__
ENV VITE_RESPONSES_STREAM=__VITE_RESPONSES_STREAM_PLACEHOLDER__
ENV VITE_RESPONSES_PARTIAL_IMAGES=__VITE_RESPONSES_PARTIAL_IMAGES_PLACEHOLDER__
ENV VITE_API_PROXY_AVAILABLE=__VITE_API_PROXY_AVAILABLE_PLACEHOLDER__
ENV VITE_API_PROXY_LOCKED=__VITE_API_PROXY_LOCKED_PLACEHOLDER__
ENV VITE_API_PROXY_AUTH_MANAGED=__VITE_API_PROXY_AUTH_MANAGED_PLACEHOLDER__
ENV VITE_HIDE_API_CONFIG=__VITE_HIDE_API_CONFIG_PLACEHOLDER__
ENV VITE_SHOW_API_CONFIG=__VITE_SHOW_API_CONFIG_PLACEHOLDER__
ENV VITE_DOCKER_DEPLOYMENT=__VITE_DOCKER_DEPLOYMENT_PLACEHOLDER__
ENV VITE_DOCKER_LEGACY_API_URL_USED=__VITE_DOCKER_LEGACY_API_URL_USED_PLACEHOLDER__

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

# ---- Production stage ----
FROM nginx:alpine

RUN apk add --no-cache openssl

ENV HOST=0.0.0.0
ENV PORT=80
ENV DEFAULT_API_URL=
ENV DEFAULT_API_MODE=
ENV DEFAULT_MODEL=
ENV DEFAULT_API_TIMEOUT=600
ENV DEFAULT_CODEX_CLI=false
ENV DEFAULT_REASONING_EFFORT=
ENV DISABLE_RESPONSE_STORAGE=false
ENV RESPONSES_STREAM=false
ENV RESPONSES_PARTIAL_IMAGES=1
ENV API_PROXY_URL=
ENV API_PROXY_API_KEY=
ENV API_PROXY_CONNECT_TIMEOUT=60s
ENV API_PROXY_SEND_TIMEOUT=1800s
ENV API_PROXY_READ_TIMEOUT=1800s
ENV ENABLE_API_PROXY=false
ENV LOCK_API_PROXY=false
ENV HIDE_API_CONFIG=false
ENV SHOW_API_CONFIG=false
ENV BASIC_AUTH_USERNAME=
ENV BASIC_AUTH_PASSWORD=
ENV BASIC_AUTH_REALM=Restricted
ENV APP_CONFIG_FILE=/etc/gpt-image-playground/config.env

COPY --from=build /app/dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/templates/default.conf.template
COPY --chmod=755 deploy/load-app-config.envsh /docker-entrypoint.d/01-load-app-config.envsh
COPY --chmod=755 deploy/migrate-api-env.envsh /docker-entrypoint.d/05-migrate-api-env.envsh
COPY --chmod=755 deploy/setup-basic-auth.envsh /docker-entrypoint.d/06-setup-basic-auth.envsh
COPY --chmod=755 deploy/inject-api-url.sh /docker-entrypoint.d/40-inject-api-url.sh

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
